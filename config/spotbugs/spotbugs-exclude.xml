<?xml version="1.0" encoding="UTF-8"?>
<FindBugsFilter>
  <!-- Sample excludes (adjust to your packages/classes) -->

  <!-- Example: ignore generated sources -->
  <Match>
    <Source name="~.*/build/generated/.*"/>
  </Match>

  <!-- Example: ignore a specific warning type in a class -->
  <!--
  <Match>
    <Class name="com.equityseer.api.LegacyController"/>
    <Bug pattern="NP_NULL_ON_SOME_PATH"/>
  </Match>
  -->

  <!-- Exclude EI_EXPOSE_REP2 for Spring DI services (false positive) -->
  <Match>
    <Class name="com.equityseer.service.bhav.BhavProcessorImpl"/>
    <Bug pattern="EI_EXPOSE_REP2"/>
  </Match>

  <!-- Alternative: exclude by field name -->
  <Match>
    <Class name="com.equityseer.service.bhav.BhavProcessorImpl"/>
    <Field name="stockService"/>
    <Bug pattern="EI_EXPOSE_REP2"/>
  </Match>
</FindBugsFilter>
