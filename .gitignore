################################################################################
# Gradle (build artifacts)
################################################################################
.gradle/
**/build/

################################################################################
# Java (compiled artifacts)
################################################################################
*.class

################################################################################
# Spring Boot / Java packaging outputs
################################################################################
*.jar
*.war
*.ear

# Keep Gradle wrapper JAR (do not ignore)
!gradle/wrapper/gradle-wrapper.jar

################################################################################
# Logs
################################################################################
*.log
logs/
**/logs/

################################################################################
# Code quality / test / coverage reports (Checkstyle, SpotBugs, tests, JaCoCo)
################################################################################
**/build/reports/
**/build/test-results/
**/build/jacoco/
**/build/tmp/

################################################################################
# Environment-specific / local config
################################################################################
.env
.env.*
**/.env
**/.env.*

**/application-local.yml
**/application-local.yaml
**/application-local.properties
**/application-local-*.yml
**/application-local-*.yaml
**/application-local-*.properties

################################################################################
# IDEs
################################################################################
# IntelliJ IDEA
.idea/
*.iml
out/

# VS Code
.vscode/

################################################################################
# OS (macOS + Windows)
################################################################################
.DS_Store
Thumbs.db

